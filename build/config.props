<Project ToolsVersion="15.0">

  <!-- Dependency versions -->
  <PropertyGroup>
    <NuGetPackageVersion>7.0.1</NuGetPackageVersion>
    <AzureStorageBlobsVersion>12.26.0</AzureStorageBlobsVersion>
    <JsonVersion>13.0.4</JsonVersion>
    <CommandLineUtilsVersion>4.1.1</CommandLineUtilsVersion>
    <NuGetTestHelpersVersion>2.1.39</NuGetTestHelpersVersion>
    <PortablePdbVersion>1.6.0</PortablePdbVersion>
    <AWSSDKVersion>4.0.15.1</AWSSDKVersion>
    <AWSSDKTokenVersion>4.0.5.4</AWSSDKTokenVersion>
    <AWSSDKSSOVersion>4.0.2.8</AWSSDKSSOVersion>
    <AWSSDKSSOOIDCVersion>4.0.3.9</AWSSDKSSOOIDCVersion>
    <DotNetConfigVersion>1.2.0</DotNetConfigVersion>
    <AzureIdentityVersion>1.17.1</AzureIdentityVersion>
  </PropertyGroup>

  <!-- Config -->
  <PropertyGroup>
    <RepositoryName>Sleet</RepositoryName>
    <PackageIconPath>$(MSBuildThisFileDirectory)/icons/icon.png</PackageIconPath>
  </PropertyGroup>

  <!-- Nuspec defaults -->
  <PropertyGroup>
    <PackageProjectUrl>https://github.com/emgarten/Sleet</PackageProjectUrl>
    <RepositoryUrl>https://github.com/emgarten/Sleet</RepositoryUrl>
    <PackageTags>nuget nugetserver nugetfeed sleet</PackageTags>
    <Description>A static nuget feed generator for Azure Storage, AWS S3, and more.</Description>
  </PropertyGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);NU1903</NoWarn>
  </PropertyGroup>

  <!-- Analyzers -->
   <PropertyGroup>
      <AnalysisMode>Recommended</AnalysisMode>
      <NoWarn>$(NoWarn);CA2211;CA1308;CA2007;CA1051</NoWarn>
   </PropertyGroup>

</Project>
